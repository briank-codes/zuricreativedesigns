><script nonce="">$RC("B:1b","S:1b")</script><script nonce="">self.__next_f.push([1,"7e:{\"data\":{\"conversationStartersByType\":[{\"id\":\"1160817599256623\",\"text\":\"Create a video from my photo\",\"longPrompt\":\"Create a video from my photo\",\"type\":\"imagine_animate\",\"attachment_type\":\"MEDIA_PICKER\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"25050773674508010\",\"text\":\"Create an image of a 90s robot\",\"longPrompt\":\"Create an image of a detailed, hand-painted plastic model of a 90s-era giant Japanese transforming robot set in a diorama. The robot is posed in an action stance, capturing dynamic movement. The scene is viewed from an upward-angle shot taken with a mobile phone, giving it a dramatic yet homemade, gritty quality that enhances the nostalgic, action-packed feel of the scene.\",\"type\":\"imagine\",\"attachment_type\":\"NONE\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"25436948995966198\",\"text\":\"Restyle my photo as a gift reveal\",\"longPrompt\":\"Transform the photo so that it looks like the subject is bursting out of a torn festive wrapping-paper frame. Add ripped gift-wrap edges around the image with folded paper textures, festive patterns and shadows that make the tear look three-dimensional. Keep the subject's face, pose, clothing and all objects in the original scene exactly the same, but make them appear as if they are popping out from inside an unwrapped gift. Do not alter the background or the composition of the original photo – only add the torn wrapping-paper frame and the stylised gift-reveal effect. Make the colours vibrant\",\"type\":\"imagine_media_picker\",\"attachment_type\":\"MEDIA_PICKER\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"2442248016278444\",\"text\":\"Discover breakout music artists\",\"longPrompt\":\"Who are the breakout music artists blowing up on Instagram right now?\",\"type\":\"learn\",\"attachment_type\":\"NONE\",\"category\":\"TRENDING\",\"responseDisplayMode\":\"full_prompt\"}]}}\n"])</script><script nonce="">$RC("B:24","S:24")</script><script nonce="">self.__next_f.push([1,"81:{\"data\":{\"conversationStartersByType\":[{\"id\":\"1160817599256623\",\"text\":\"Create a video from my photo\",\"longPrompt\":\"Create a video from my photo\",\"type\":\"imagine_animate\",\"attachment_type\":\"MEDIA_PICKER\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"1438536140561401\",\"text\":\"Create a video of raccoons from a back garden camera\",\"longPrompt\":\"Create a video in black and white, captured by a low-quality CCTV camera showing a group of raccoons jumping on a backyard trampoline at night. Their eyes glow eerily as they look towards the camera, creating a mysterious and slightly unsettling scene. The overall mood is dark and suspicious, emphasising the grainy, old-school security camera vibe.\",\"type\":\"imagine_video\",\"attachment_type\":\"NONE\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"3817915051840653\",\"text\":\"Create a video of a bear in an apron\",\"longPrompt\":\"Create a video of an old, gruff, grizzled brown bear in a green apron and spectacles, scrutinises plumbing parts, sighing loudly in a brightly lit, disorganized hardware store, exuding cosy autumnal anthropomorphic charm.\",\"type\":\"imagine_video\",\"attachment_type\":\"NONE\",\"category\":null,\"responseDisplayMode\":null},{\"id\":\"805989145414738\",\"text\":\"Create a video of an owl librarian\",\"longPrompt\":\"Create a video of an elderly distinguished barn owl, large glasses on beak, cosy blanket draped, reading a good book in his autumnal den, gentle firelight dancing, serene, anthropomorphic.\",\"type\":\"imagine_video\",\"attachment_type\":\"NONE\",\"category\":null,\"responseDisplayMode\":null}]}}\n"])</script><script nonce="">$RC("B:27","S:27")</script><next-route-announcer style="position: absolute;"><template shadowrootmode="open"><div aria-live="assertive" id="__next-route-announcer__" role="alert" style="position: absolute; border: 0px; height: 1px; margin: -1px; padding: 0px; width: 1px; clip: rect(0px, 0px, 0px, 0px); overflow: hidden; white-space: nowrap; overflow-wrap: normal;"></div></template></next-route-announcer></body></html>